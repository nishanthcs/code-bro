{
  "name": "codebro",
  "version": "0.1.0",
  "description": "Local-first Python playground for coding interview and data structures and algorithms practice",
  "keywords": [
    "python",
    "coding-interviews",
    "data-structures",
    "algorithms",
    "dsa",
    "leetcode",
    "python-playground",
    "windows",
    "linux",
    "local-first"
  ],
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "start": "npm run build && .venv/bin/codebro",
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "npm run dev --workspace frontend",
    "test": "npm run test --workspace frontend",
    "lint": "npm run lint --workspace frontend",
    "typecheck": "npm run typecheck --workspace frontend",
    "build": "npm run build --workspace frontend",
    "smoke:python": "node scripts/smoke-pyodide.mjs",
    "smoke:ui": "node scripts/smoke-ui.mjs"
  },
  "engines": {
    "node": "24.16.0"
  },
  "devDependencies": {
    "playwright-core": "1.61.0"
  }
}
